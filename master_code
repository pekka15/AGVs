void advancePreBufferChain()
{
  if (!bufferOccupied && preBuffer1Occupied)
  {
    String agv = preBuffer1AGV;
    clearPreBufferStorage("1");
    sendToAGVByName(agv, "CONTINUE_15");
    Serial.println("PB1 → BUFFER");
  }

  if (!preBuffer1Occupied && preBuffer2Occupied)
  {
    String agv = preBuffer2AGV;
    clearPreBufferStorage("2");
    sendToAGVByName(agv, "CONTINUE_15");
    Serial.println("PB2 → PB1");
  }

  if (!preBuffer2Occupied && preBuffer3Occupied)
  {
    String agv = preBuffer3AGV;
    clearPreBufferStorage("3");
    sendToAGVByName(agv, "CONTINUE_15");
    Serial.println("PB3 → PB2");
  }

  if (!preBuffer3Occupied && preBuffer4Occupied)
  {
    String agv = preBuffer4AGV;
    clearPreBufferStorage("4");
    sendToAGVByName(agv, "CONTINUE_15");
    Serial.println("PB4 → PB3");
  }

  if (!preBuffer4Occupied && preBuffer5Occupied)
  {
    String agv = preBuffer5AGV;
    clearPreBufferStorage("5");
    sendToAGVByName(agv, "CONTINUE_15");
    Serial.println("PB5 → PB4");
  }
}

