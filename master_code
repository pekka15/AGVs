void sendContinueWithCurrentSpeed(const String &agvName)
{
  char cmd[20];
  snprintf(cmd, sizeof(cmd), "CONTINUE_%d", continuousSpeed);
  sendToAGVByName(agvName, cmd);
}


void releaseContinuousEntry(const String &agvName, const String &station)
{
  if (continuousLineStopped)
  {
    sendToAGVByName(agvName, "WAIT");
    Serial.println("Continuous line stopped -> WAIT");
    return;
  }

  Serial.print("RELEASE -> ");
  Serial.print(agvName);
  Serial.print(" from station ");
  Serial.println(station);

  clearStationStorage(station);

  if (station == "1")
  {
    setAGVZone(agvName, "ON_LINE");
  }
  else if (station == "BUFFER")
  {
    setAGVZone(agvName, "AT_1_PENDING");
  }

  // 🔥 SPEED LOGIC HERE
  if (station == "BUFFER")
  {
    sendToAGVByName(agvName, "CONTINUE_15");   // full speed
  }
  else
  {
    sendContinueWithCurrentSpeed(agvName);  // controlled speed
  }

  Serial.print("Released ");
  Serial.print(agvName);
  Serial.print(" from ");
  Serial.println(station);
}

// =====================================================
// MESSAGE PARSER - OP 2 (CONTINUOUS LINE)
// =====================================================
void processIncomingMessageContinuous(String fullMessage)
{
  fullMessage.trim();
  fullMessage.toUpperCase();
  fullMessage.replace(" ", "_");

  int colonIndex = fullMessage.indexOf(':');
  if (colonIndex == -1)
  {
    Serial.println("Invalid message format");
    return;
  }

  String agvName = fullMessage.substring(0, colonIndex);
  String command = fullMessage.substring(colonIndex + 1);
  // =====================================================
// MAP STATION 8-13 TO PREBUFFER SYSTEM
// =====================================================

  if      (command == "AT_STATION_8")  command = "AT_PREBUFFER_5";
  else if (command == "AT_STATION_9")  command = "AT_PREBUFFER_4";
  else if (command == "AT_STATION_10") command = "AT_PREBUFFER_3";
  else if (command == "AT_STATION_11") command = "AT_PREBUFFER_2";
  else if (command == "AT_STATION_12") command = "AT_PREBUFFER_1";
  else if (command == "AT_STATION_13") command = "AT_BUFFER";

  else if (command == "REQUEST_STATION_8")  command = "REQUEST_PREBUFFER_5";
  else if (command == "REQUEST_STATION_9")  command = "REQUEST_PREBUFFER_4";
  else if (command == "REQUEST_STATION_10") command = "REQUEST_PREBUFFER_3";
  else if (command == "REQUEST_STATION_11") command = "REQUEST_PREBUFFER_2";
  else if (command == "REQUEST_STATION_12") command = "REQUEST_PREBUFFER_1";
  else if (command == "REQUEST_STATION_13") command = "REQUEST_BUFFER";


  Serial.print("PROCESS OP2 -> ");
  Serial.println(fullMessage);
  // =====================================================
  // ARRIVALS
  // =====================================================
// =====================================================
// PREBUFFER REQUESTS
// =====================================================

  if (command == "REQUEST_PREBUFFER_5")
  {
      handlePreBufferMoveRequest(agvName, "5");
      return;
  }
  else if (command == "REQUEST_PREBUFFER_4")
  {
      handlePreBufferMoveRequest(agvName, "4");
      return;
  }
  else if (command == "REQUEST_PREBUFFER_3")
  {
      handlePreBufferMoveRequest(agvName, "3");
      return;
  }
  else if (command == "REQUEST_PREBUFFER_2")
  {
      handlePreBufferMoveRequest(agvName, "2");
      return;
  }
  else if (command == "REQUEST_PREBUFFER_1")
  {
      handlePreBufferMoveRequest(agvName, "1");
      return;
  }
  
  if (command == "AT_STATION_1")
  {
    handleArrivalMessage(agvName, "1");

  }
  else if (command == "AT_STATION_2")
  {
    handleArrivalMessage(agvName, "2");

    if (!continuousLineStopped)
    {
      clearStationStorage("2");
      sendContinueWithCurrentSpeed(agvName);
    }
  }
  else if (command == "AT_STATION_3")
  {
    handleArrivalMessage(agvName, "3");

    if (!continuousLineStopped)
    {
      clearStationStorage("3");
      sendContinueWithCurrentSpeed(agvName);
    }
  }
  else if (command == "AT_STATION_4")
  {
    handleArrivalMessage(agvName, "4");

    if (!continuousLineStopped)
    {
      clearStationStorage("4");
      sendContinueWithCurrentSpeed(agvName);
    }
  }
  else if (command == "AT_STATION_5")
  {
    handleArrivalMessage(agvName, "5");

    if (!continuousLineStopped)
    {
      clearStationStorage("5");
      sendContinueWithCurrentSpeed(agvName);
    }
  }
  else if (command == "AT_STATION_6")
  {
    handleArrivalMessage(agvName, "6");

    if (!continuousLineStopped)
    {
      clearStationStorage("6");
      sendContinueWithCurrentSpeed(agvName);
    }
  }
  else if (command == "AT_STATION_7")
  {
    Serial.println("AGV reached STATION 7 -> STOP LINE");

    station7Occupied = true;
    station7AGV = agvName;

    updateHMIStation("tsstatus7", true);

    // 🔥 STOP ENTIRE LINE
    stopContinuousLine();
  }
  else if (command == "AT_BUFFER")
  {
    Serial.println("AGV reached BUFFER");

    handleArrivalMessage(agvName, "BUFFER");

    return;
  }
  else if (command == "REQUEST_BUFFER")
  {
    if (bufferAGV == agvName)
    {
      if (!station1Occupied)
      {
        Serial.println("OP2 -> BUFFER → STATION 1 allowed");

        clearStationStorage("BUFFER");

        // AGV not on line yet
        setAGVZone(agvName, "AT_1_PENDING");

        // Move from buffer to station 1
        sendToAGVByName(agvName, "CONTINUE_15");

        advancePreBufferChain();
        return;
      }
      else
      {
        sendToAGVByName(agvName, "WAIT");
        Serial.println("Station 1 occupied, wait at BUFFER");
        return;
      }
    }
  }

  // =====================================================
  // REQUESTS
  // =====================================================
  else if (command == "REQUEST_STATION_1")
  {
    if (station1AGV == agvName)
    {
      releaseContinuousEntry(agvName, "1"); 
    }
  }
  
  else if (command == "REQUEST_STATION_7")
  {
      if (station7AGV == agvName)
      {
          clearStationStorage("7");

          // Release AGV at station 7 out of the line
          sendToAGVByName(agvName, "CONTINUE_15");

          setAGVZone(agvName, "OFF_LINE");

          continuousLineStopped = false;

          // Resume all AGVs already on the line
          for (int i = 1; i <= 12; i++)
          {
              String otherAgv = "AGV" + String(i);

              if (agvZone[i] == "ON_LINE" && otherAgv != agvName)
              {
                  sendContinueWithCurrentSpeed(otherAgv);
              }
          }
      }
  }

  else if (command == "CHARGING")
  {
    int agvNum = getAGVIndexFromName(agvName);
    updateAGVCharging(agvNum, true);
    return;
  }

  else if (command == "NOT_CHARGING")
  {
    int agvNum = getAGVIndexFromName(agvName);
    updateAGVCharging(agvNum, false);
    return;
  }
  else if (command == "AT_PREBUFFER_5") handlePreBufferArrival(agvName, "5");
  else if (command == "AT_PREBUFFER_4") handlePreBufferArrival(agvName, "4");
  else if (command == "AT_PREBUFFER_3") handlePreBufferArrival(agvName, "3");
  else if (command == "AT_PREBUFFER_2") handlePreBufferArrival(agvName, "2");
  else if (command == "AT_PREBUFFER_1") handlePreBufferArrival(agvName, "1");
  // =====================================================
  // UNKNOWN
  // =====================================================
  else
  {
    Serial.print("Unknown OP2 command: ");
    Serial.println(command);
  }
}


