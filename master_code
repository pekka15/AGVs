void handlePreBufferMoveRequest(const String &agvName, const String &currentSlot)
{
  if (currentSlot == "5")
  {
    if (preBuffer5AGV == agvName)
    {
      if (!preBuffer4Occupied)
      {
        clearPreBufferStorage("5");
        sendToAGVByName(agvName, "CONTINUE_15");
        advancePreBufferChain();
        Serial.println("PREBUFFER 5 -> 4 allowed");
      }
      else
      {
        sendToAGVByName(agvName, "WAIT");
        Serial.println("PREBUFFER 4 occupied, wait at PREBUFFER 5");
      }
    }
    return;
  }

  if (currentSlot == "4")
  {
    if (preBuffer4AGV == agvName)
    {
      if (!preBuffer3Occupied)
      {
        clearPreBufferStorage("4"); 
        sendToAGVByName(agvName, "CONTINUE_15");
        advancePreBufferChain();
        Serial.println("PREBUFFER 4 -> 3 allowed");
      }
      else
      {
        sendToAGVByName(agvName, "WAIT");
        Serial.println("PREBUFFER 3 occupied, wait at PREBUFFER 4");
      }
    }
    return;
  }

  if (currentSlot == "3")
  {
    if (preBuffer3AGV == agvName)
    {
      if (!preBuffer2Occupied)
      {
        clearPreBufferStorage("3");
        sendToAGVByName(agvName, "CONTINUE_15");
        advancePreBufferChain();
        Serial.println("PREBUFFER 3 -> 2 allowed");
      }
      else
      {
        sendToAGVByName(agvName, "WAIT");
        Serial.println("PREBUFFER 2 occupied, wait at PREBUFFER 3");
      }
    }
    return;
  }

  if (currentSlot == "2")
  {
    if (preBuffer2AGV == agvName)
    {
      if (!preBuffer1Occupied)
      {
        clearPreBufferStorage("2"); 
        sendToAGVByName(agvName, "CONTINUE_15");
        advancePreBufferChain();
        Serial.println("PREBUFFER 2 -> 1 allowed");
      }
      else
      {
        sendToAGVByName(agvName, "WAIT");
        Serial.println("PREBUFFER 1 occupied, wait at PREBUFFER 2");
      }
    }
    return;
  }

  if (currentSlot == "1")
  {
    if (preBuffer1AGV == agvName)
    {
      if (!bufferOccupied)
      {
        clearPreBufferStorage("1");
        sendToAGVByName(agvName, "CONTINUE_15");
        advancePreBufferChain();
        Serial.println("PREBUFFER 1 -> BUFFER allowed");
      }
      else
      {
        sendToAGVByName(agvName, "WAIT");
        Serial.println("BUFFER occupied, wait at PREBUFFER 1");
      }
    }
    return;
  }
}


int getAGVIndexFromName(const String &agvName)
{
  if (agvName.startsWith("AGV"))
  {
    return agvName.substring(3).toInt();
  }
  return 0;
}

void setAGVZone(const String &agvName, const String &zone)
{  
  Serial.print("ZONE -> ");
  Serial.print(agvName);
  Serial.println(" = ON_LINE");
  int idx = getAGVIndexFromName(agvName);

  if (idx >= 1 && idx <= 12)
  {
    agvZone[idx] = zone;

    Serial.print("ZONE -> ");
    Serial.print(agvName);
    Serial.print(" = ");
    Serial.println(zone);
  }
}

bool isAGVOnLine(const String &agvName)
{
  int idx = getAGVIndexFromName(agvName);

  if (idx >= 1 && idx <= 12)
  {
    return agvZone[idx] == "ON_LINE";
  }

  return false;
}
