// =====================================================
// NEXTION READER
// =====================================================
void readNextion()
{ 
  while (Serial2.available())
  {
    uint8_t b = Serial2.read();
    if (b == 0xFF)
    {
      ffCount++;

      if (ffCount == 3)
      {
        nextionBuffer.trim();
        nextionBuffer.toUpperCase();

        bool printable = true;
        for (int k = 0; k < nextionBuffer.length(); k++)
        {
          char c = nextionBuffer[k];
          if (c < 32 || c > 126)
          {
            printable = false;
            break;
          }
        }

        if (printable && nextionBuffer.length() > 0)
        { 

          if (nextionBuffer == "REFRESH_CHARGE")
          {
            Serial.println("Refreshing charging HMI...");
            refreshChargingHMI();
          }

          if (nextionBuffer == "OP_STATION")
          {
            int oldMode = operatingMode;
            operatingMode = 1;
            handleOperatingModeChange(oldMode, operatingMode);
            stationModeEnabled = true;
            Serial.println("MODE = STATION");
            startHMIRefreshWindow();
          }
          else if (nextionBuffer == "OP_CONTINUOUS")
          { int oldMode = operatingMode;
            operatingMode = 2;
            handleOperatingModeChange(oldMode, operatingMode);
            stationModeEnabled = false;
            continuousLineStopped = false;
            Serial.println("MODE = CONTINUOUS");
            startHMIRefreshWindow();
          }
          else if (nextionBuffer == "OP_COMMAND")
          { int oldMode = operatingMode;
            operatingMode = 3;
            handleOperatingModeChange(oldMode, operatingMode);
            stationModeEnabled = false;
            Serial.println("MODE = COMMAND");
            startHMIRefreshWindow();
          }
          else if (nextionBuffer == "MOVE_OP3")
          {
            Serial.print("MOVE_OP3 received, operatingMode = ");
            Serial.println(operatingMode);

            if (operatingMode == 3)
            {
              if (isStation7Active())
              {
                Serial.println("OP3 MOVE ignored: AGV at Station 7");
              }
              else
              {
                moveAllAGVsOp3();
              }
            }
          }
          else if (nextionBuffer == "STOP_OP3")
          {
            Serial.print("STOP_OP3 received, operatingMode = ");
            Serial.println(operatingMode);

            if (operatingMode == 3)
            {
              if (isStation7Active())
              {
                Serial.println("OP3 STOP ignored: AGV at Station 7");
              }
              else
              {
                stopAllAGVsOp3();
              }
            }
          }
          else if (nextionBuffer == "SPEED1")  { continuousSpeed = 1;  Serial.println("Continuous speed = 1"); }
          else if (nextionBuffer == "SPEED2")  { continuousSpeed = 2;  Serial.println("Continuous speed = 2"); }
          else if (nextionBuffer == "SPEED3")  { continuousSpeed = 3;  Serial.println("Continuous speed = 3"); }
          else if (nextionBuffer == "SPEED4")  { continuousSpeed = 4;  Serial.println("Continuous speed = 4"); }
          else if (nextionBuffer == "SPEED5")  { continuousSpeed = 5;  Serial.println("Continuous speed = 5"); }
          else if (nextionBuffer == "SPEED6")  { continuousSpeed = 6;  Serial.println("Continuous speed = 6"); }
          else if (nextionBuffer == "SPEED7")  { continuousSpeed = 7;  Serial.println("Continuous speed = 7"); }
          else if (nextionBuffer == "SPEED8")  { continuousSpeed = 8;  Serial.println("Continuous speed = 8"); }
          else if (nextionBuffer == "SPEED9")  { continuousSpeed = 9;  Serial.println("Continuous speed = 9"); }
          else if (nextionBuffer == "SPEED10") { continuousSpeed = 10; Serial.println("Continuous speed = 10"); }
          else if (nextionBuffer == "SPEED11") { continuousSpeed = 11; Serial.println("Continuous speed = 11"); }
          else if (nextionBuffer == "SPEED12") { continuousSpeed = 12; Serial.println("Continuous speed = 12"); }
          else if (nextionBuffer == "SPEED13") { continuousSpeed = 13; Serial.println("Continuous speed = 13"); }
          else if (nextionBuffer == "SPEED14") { continuousSpeed = 14; Serial.println("Continuous speed = 14"); }
          else if (nextionBuffer == "SPEED15") { continuousSpeed = 15; Serial.println("Continuous speed = 15"); }
      
          else if (nextionBuffer == "STOP_LINE")
          {
            Serial.print("STOP_LINE received, operatingMode = ");
            Serial.println(operatingMode);

            if (operatingMode == 2)
            {
              if (isStation7Active())
              {
                Serial.println("OP2 STOP ignored: AGV at Station 7");
              }
              else
              {
                stopContinuousLineManual();
              }
            }
          }
          else if (nextionBuffer == "START_LINE")
          {
            Serial.print("START_LINE received, operatingMode = ");
            Serial.println(operatingMode);

            if (operatingMode == 2)
            {
              if (isStation7Active())
              {
                Serial.println("OP2 START ignored: AGV at Station 7");
              }
              else
              {
                continueContinuousLineManual();
              }
            }
          }
          else
          {
            Serial.print("Ignored Nextion packet: ");
            Serial.println(nextionBuffer);
          }
        }

        nextionBuffer = "";
        ffCount = 0;
      }
    }
    else
    {
      if (nextionBuffer.length() == 0 && (b < 32 || b > 126))
      {
        continue;
      }

      ffCount = 0;
      nextionBuffer += (char)b;
    }
  }
}

// =====================================================
// ADD ALL AGVS AS PEERS
// =====================================================
void addAllPeers()
{
  for (int i = 0; i < NUM_AGVS; i++)
  {
    esp_now_peer_info_t peerInfo = {};
    memcpy(peerInfo.peer_addr, agvs[i].mac, 6);
    peerInfo.channel = 13;
    peerInfo.encrypt = false;

    if (esp_now_add_peer(&peerInfo) == ESP_OK)
    {
      Serial.print("Peer added: ");
      Serial.println(agvs[i].name);
    }
    else
    {
      Serial.print("Failed to add peer: ");
      Serial.println(agvs[i].name);
    }
  }
}

// =====================================================
// SETUP
// =====================================================
void setup()
{
  Serial.begin(115200);
  Serial2.begin(9600, SERIAL_8N1, NEXTION_RX, NEXTION_TX);

  WiFi.mode(WIFI_STA);
  esp_wifi_set_channel(13, WIFI_SECOND_CHAN_NONE);

  if (esp_now_init() != ESP_OK)
  {
    Serial.println("ESP-NOW init failed");
    return;
  }

  esp_now_register_recv_cb(onDataRecv);
  addAllPeers();

  Serial.println("Master ready");

  sendNextionCommand("page page1");
  delay(400);

  clearSystemMemory();
  refreshHMIFromMemory();

  operatingMode = 1;
  stationModeEnabled = true;
  Serial.println("MODE = STATION (forced in setup for testing)");
}

// =====================================================
// LOOP
// =====================================================
void loop()
{
  readNextion();

  if (hmiRefreshActive)
  {
    if (millis() - lastHMIRefresh >= 80)
    {
      lastHMIRefresh = millis();
      refreshHMIFromMemory();
    }

    if (millis() - hmiRefreshStartTime >= 500)
    {
      hmiRefreshActive = false;
    }
  }
}

