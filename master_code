// =====================================================
// ESP-NOW RECEIVE
// =====================================================
void onDataRecv(const esp_now_recv_info_t *info, const uint8_t *data, int len)
{

  // 🔥 DEBUG: PRINT SENDER MAC
  Serial.print("RX FROM: ");
  for (int i = 0; i < 6; i++) {
    Serial.print(info->src_addr[i], HEX);
    if (i < 5) Serial.print(":");
  }
  Serial.println();
  // ==========================================
  // READ MESSAGE (YOUR ORIGINAL METHOD)
  // ==========================================
  message incomingMsg;
  memset(&incomingMsg, 0, sizeof(incomingMsg));
  memcpy(&incomingMsg, data, min(len, (int)sizeof(incomingMsg)));

  String incoming = String(incomingMsg.text);
  incoming.trim();
  incoming.toUpperCase();

  int agvNumber = getAGVNumberFromMAC(info->src_addr);

  if (agvNumber < 0)
  {
    Serial.println("Unknown AGV MAC");
    return;
  }

  Serial.print("RX AGV");
  Serial.print(agvNumber);
  Serial.print(" -> ");
  Serial.println(incoming);

  // ==========================================
  // CHARGING HANDLING (NEW)
  // ==========================================
  if (incoming == "CHARGING")
  {
    updateAGVCharging(agvNumber, true);
    return;
  }

  if (incoming == "NOT_CHARGING")
  {
    updateAGVCharging(agvNumber, false);
    return;
  }

  // ==========================================
  // ORIGINAL SYSTEM (UNCHANGED)
  // ==========================================
  String fullMessage = "AGV" + String(agvNumber) + ":" + incoming;

  Serial.print("ESP-NOW RX -> ");
  Serial.println(fullMessage);

  // =====================================================
  // PROCESS MESSAGE IMMEDIATELY
  // =====================================================

  if (operatingMode == 1)
  {
      processIncomingMessageStation(fullMessage);
  }
  else if (operatingMode == 2)
  {
      processIncomingMessageContinuous(fullMessage);
  }
  else if (operatingMode == 3)
  {
      processIncomingMessageCommand(fullMessage);
  }
}

