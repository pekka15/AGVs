int getAGVNumberFromMAC(const uint8_t *mac)
{
  for (int i = 0; i < NUM_AGVS; i++)
  {
    if (memcmp(mac, agvs[i].mac, 6) == 0)
    {
      return i + 1;
    }
  }
  return -1;
}

void sendToAGVByName(const String &agvName, const char *cmd)
{
  memset(&msg, 0, sizeof(msg));
  strncpy(msg.text, cmd, sizeof(msg.text) - 1);

  for (int i = 0; i < NUM_AGVS; i++)
  {
    if (agvName.equalsIgnoreCase(agvs[i].name))
    {
      esp_now_send(agvs[i].mac, (uint8_t *)&msg, sizeof(msg));

      Serial.print("MASTER -> ");
      Serial.print(agvName);
      Serial.print(": ");
      Serial.println(cmd);
      return;
    }
  }

  Serial.print("Unknown AGV name: ");
  Serial.println(agvName);
}

