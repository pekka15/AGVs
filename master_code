// =====================================================
void updateAGVCharging(int agvNumber, bool charging)
{
  if (agvNumber < 1 || agvNumber > 12) return;

  // 🔥 STORE STATE
  agvChargingState[agvNumber] = charging;

  // 🔥 UPDATE HMI (only if visible)
  String cmd;

  if (charging)
  {
    cmd = "tCharge" + String(agvNumber) + ".txt=\"Charging\"";
    sendNextionCommand(cmd);

    cmd = "tCharge" + String(agvNumber) + ".bco=2016";
    sendNextionCommand(cmd);
  }
  else
  {
    cmd = "tCharge" + String(agvNumber) + ".txt=\"Not Charging\"";
    sendNextionCommand(cmd);

    cmd = "tCharge" + String(agvNumber) + ".bco=65504";
    sendNextionCommand(cmd);
  }

  cmd = "ref tCharge" + String(agvNumber);
  sendNextionCommand(cmd);

  Serial.print("CHARGE UPDATE -> AGV");
  Serial.println(agvNumber);
}

void refreshChargingHMI()
{
  for (int i = 1; i <= 12; i++)
  {
    updateAGVCharging(i, agvChargingState[i]);
    delay(20); // prevent Nextion overload
  }
}


void handleOperatingModeChange(int oldMode, int newMode)
{
  Serial.print("MODE CHANGE: ");
  Serial.print(oldMode);
  Serial.print(" -> ");
  Serial.println(newMode);

  // =====================================================
  // OP2 / OP3 → OP1
  // =====================================================
  if (oldMode != newMode)
  {
    Serial.println("OP2/OP3 -> OP1: CLEAR stations + CONTINUE line");

    // =====================================================
    // 🔥 CLEAR STATION MEMORY ONLY (NOT agvZone!)
    // =====================================================
    station1Occupied = false;
    station2Occupied = false;
    station3Occupied = false;
    station4Occupied = false;
    station5Occupied = false;
    station6Occupied = false;
    station7Occupied = false;
    bufferOccupied   = false;

    station1AGV = "";
    station2AGV = "";
    station3AGV = "";
    station4AGV = "";
    station5AGV = "";
    station6AGV = "";
    station7AGV = "";
    bufferAGV   = "";

    // =====================================================
    // REQUEST CURRENT AGV LOCATIONS
    // =====================================================

    Serial.println("Requesting AGV locations...");

    for (int i = 1; i <= 12; i++)
    {
        String agvName = "AGV" + String(i);
        sendToAGVByName(agvName, "REPORT_LOCATION");
    }

    delay(500);

    Serial.println("Location rebuild complete");
    // =====================================================
    // 🔥 CONTINUE ALL AGVs ON THE LINE
    // ====================================================

    continuousLineStopped = false;
  
  }
  delay(1500);

// REFRESH HMI AFTER REBUILD
  refreshHMIFromMemory();

  Serial.println("HMI rebuild complete");
    // =====================================================
  // OP1 → OP2
  // =====================================================
  if (oldMode == 1 && newMode == 2)
  {
    Serial.println("Switching to OP2 -> apply continuous speed");

    for (int i = 1; i <= 12; i++)
    {
      if (agvZone[i] == "ON_LINE")
      {
        String agvName = "AGV" + String(i);

        sendContinueWithCurrentSpeed(agvName); // CONTINUE_X
      }
    }
  }

  // =====================================================
  // ANY → OP3
  // =====================================================
  if (newMode == 3)
  {
    Serial.println("Switching to OP3 -> freeze system");

    for (int i = 1; i <= 12; i++)
    {
      if (agvZone[i] == "ON_LINE")
      {
        String agvName = "AGV" + String(i);
        // sendToAGVByName(agvName, "WAIT");
      }
    }
  }
}

