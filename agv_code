void handleFinalMarker(uint8_t finalMarker)
{
  static uint8_t markers[3] = {0, 0, 0};
  static uint8_t index = 0;
  static unsigned long lastMarkerTime = 0;

  const unsigned long TIMEOUT = 10000;

  if (finalMarker < 1 || finalMarker > 3) return;

  // timeout reset
  if (millis() - lastMarkerTime > TIMEOUT)
  {
    index = 0;
  }

  lastMarkerTime = millis();

  // store marker
  // =====================================================
  // FIRST MARKER DETECTED
  // DISABLE BUMPER + ULTRASONIC IMMEDIATELY
  // =====================================================
  if (index == 0)
  {
    stationDetectionActive = true;

    ultrasonicEnabled = false;
    ultrasonicStop = false;

    Serial.println("FIRST MARKER -> SAFETY DISABLED");
  }

  // store marker
  markers[index] = finalMarker;
  index++;

  Serial.print("Marker: ");
  Serial.println(finalMarker);

  // if we have 3 markers → decode
  if (index == 3)
  {
    uint8_t first  = markers[0];
    uint8_t second = markers[1];
    uint8_t third  = markers[2];

    uint8_t station =
      (first - 1) * 9 +
      (second - 1) * 3 +
      third;

    String msg = "AT_STATION_" + String(station);

    // =====================================================
    // DISABLE SAFETY INPUTS DURING STATION APPROACH
    // =====================================================
    Serial.println("STATION DETECTED -> ULTRASONIC + BUMPER DISABLED");

    startWaitingAtLocation(msg);

    // reset for next
    index = 0;
  }
}

void checkChargingAndSend()
{
  int raw = analogRead(CT_PIN);

  // Convert to voltage (ESP32 ADC ~3.3V range)
  float voltage = (raw / 4095.0f) * 3.3f;

  // Filter it
  chargeFiltered =
    CHARGE_ALPHA * voltage +
    (1.0f - CHARGE_ALPHA) * chargeFiltered;

  Serial.print("Charge V: ");
  Serial.println(chargeFiltered, 3);

  // Hysteresis + debounce
  if (!isCharging && chargeFiltered > CHARGE_ON_THRESHOLD)
  {
    if (!chargingCandidate)
    {
      chargingCandidate = true;
      chargeStateChangeTime = millis();
    }

    if (millis() - chargeStateChangeTime > CHARGE_CONFIRM_MS)
    {
      isCharging = true;
      chargingCandidate = false;
      Serial.println("CHARGING DETECTED");
      sendToMaster("CHARGING");
    }
  }
  else if (isCharging && chargeFiltered < CHARGE_OFF_THRESHOLD)
  {
    if (!notChargingCandidate)
    {
      notChargingCandidate = true;
      chargeStateChangeTime = millis();
    }

    if (millis() - chargeStateChangeTime > CHARGE_CONFIRM_MS)
    {
      isCharging = false;
      notChargingCandidate = false;
      Serial.println("NOT CHARGING");
      sendToMaster("NOT_CHARGING");
    }
  }
  else
  {
    chargingCandidate = false;
    notChargingCandidate = false;
  }
}

