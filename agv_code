// =====================================================
void stopMotors() {
  ledcWrite(PWM_POS_PIN, 0);
  ledcWrite(PWM_NEG_PIN, 0);
  dutyPos = 0;
  dutyNeg = 0;
}

void runManualFullSpeed() {
  ledcWrite(PWM_POS_PIN, PWM_MAX);
  ledcWrite(PWM_NEG_PIN, PWM_MAX);
  dutyPos = PWM_MAX;
  dutyNeg = PWM_MAX;
}

void MaglinTracking(int16_t LD21, uint16_t &dutyNeg1, uint16_t &dutyPos1) {
  uint16_t basePos = PWM_MAX;
  uint16_t baseNeg = PWM_MAX;

  if      (LD21 > 100) basePos = 0;
  else if (LD21 > 80)  basePos = 102;
  else if (LD21 > 70)  basePos = 205;
  else if (LD21 > 60)  basePos = 307;
  else if (LD21 > 50)  basePos = 410;
  else if (LD21 > 40)  basePos = 512;
  else if (LD21 > 30)  basePos = 614;
  else if (LD21 > 20)  basePos = 717;
  else if (LD21 > 10)  basePos = 819;
  else                 basePos = PWM_MAX;

  if      (LD21 < -100) baseNeg = 0;
  else if (LD21 < -80)  baseNeg = 102;
  else if (LD21 < -70)  baseNeg = 205;
  else if (LD21 < -60)  baseNeg = 307;
  else if (LD21 < -50)  baseNeg = 410;
  else if (LD21 < -40)  baseNeg = 512;
  else if (LD21 < -30)  baseNeg = 614;
  else if (LD21 < -20)  baseNeg = 717;
  else if (LD21 < -10)  baseNeg = 819;
  else                  baseNeg = PWM_MAX;

  dutyPos1 = applySpeedScale(basePos);
  dutyNeg1 = applySpeedScale(baseNeg);

  ledcWrite(PWM_POS_PIN, dutyPos1);
  ledcWrite(PWM_NEG_PIN, dutyNeg1);

}
