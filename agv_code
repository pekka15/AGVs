void handleWaitingRequests()
{
  if (!waitingForPermission) return;
  if (waitingRequestMessage.length() == 0) return;

  if (millis() - lastPermissionRequestTime >= REQUEST_REPEAT_MS)
  {
    lastPermissionRequestTime = millis();

    Serial.print("Retry request -> ");
    Serial.println(waitingRequestMessage);

    sendToMaster(waitingRequestMessage.c_str());
  }
}
