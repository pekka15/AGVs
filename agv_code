void startWaitingAtLocation(const String &arrivalMessage)
{ 
  stationDetectionActive = false;
  // ================= ULTRASONIC CONTROL =================
  if (arrivalMessage == "AT_STATION_1" ||
      arrivalMessage == "AT_STATION_2" ||
      arrivalMessage == "AT_STATION_3" ||
      arrivalMessage == "AT_STATION_4" ||
      arrivalMessage == "AT_STATION_5")
  {
    ultrasonicEnabled = true;
    Serial.println("ULTRA ON");
  }
  else
  {
    ultrasonicEnabled = false;
    Serial.println("ULTRA OFF");
  }
  waitingArrivalMessage = arrivalMessage;
  waitingRequestMessage = mapArrivalToRequest(arrivalMessage);

  // Always stop and mark waiting
  autoMovementFlag = false;
  waitingForContinue = true;
  requestSent = false;
  stoppedAtStation = true;

  currentStationMessage = waitingArrivalMessage;
  currentRequestMessage = waitingRequestMessage;

  stopMotors();

  Serial.print("WAITING AT: ");
  Serial.println(waitingArrivalMessage);

  Serial.print("REQUEST MSG: ");
  Serial.println(waitingRequestMessage);

  // Always announce arrival first
  sendToMaster(waitingArrivalMessage.c_str());

  // -------------------------------------------------
  // ONLY prebuffers should auto-request immediately
  // -------------------------------------------------
// -------------------------------------------------
// PREBUFFER STATIONS AUTO-REQUEST
// -------------------------------------------------
  if (arrivalMessage == "AT_STATION_8"  ||
      arrivalMessage == "AT_STATION_9"  ||
      arrivalMessage == "AT_STATION_10" ||
      arrivalMessage == "AT_STATION_11" ||
      arrivalMessage == "AT_STATION_12")
  {
      waitingForPermission = true;
      lastPermissionRequestTime = 0;

      Serial.println("Prebuffer station -> automatic request enabled");
  }
  else
  {
      waitingForPermission = false;
      lastPermissionRequestTime = 0;

      Serial.println("Normal station -> waiting for button/manual request");
  }
}

void triggerManualStationRequest()
{
  if (!stoppedAtStation) return;
  if (waitingArrivalMessage.length() == 0) return;
  if (waitingRequestMessage.length() == 0) return;

  // Do not use button/manual request for prebuffers
  if (waitingArrivalMessage.startsWith("AT_PREBUFFER_")) return;

  waitingForPermission = true;
  lastPermissionRequestTime = 0;

  Serial.print("Manual request triggered -> ");
  Serial.println(waitingRequestMessage);

  sendToMaster(waitingRequestMessage.c_str());
}

