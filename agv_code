bool buttonPressedEvent() {
  bool rawReading = digitalRead(BUTTON_PIN);

  if (rawReading != lastRawButtonState) {
    lastDebounceTime = millis();
    lastRawButtonState = rawReading;
  }

  if ((millis() - lastDebounceTime) > debounceDelay) {
    if (rawReading != stableButtonState) {
      stableButtonState = rawReading;

      if (stableButtonState == LOW) {
        return true;
      }

      if (stableButtonState == HIGH) {
        Serial.println("Button released");
      }
    }
  }

  return false;
}

String cleanTag(String raw) {
  String cleaned = "";

  for (int i = 0; i < raw.length(); i++) {
    char c = raw[i];
    if ((c >= '0' && c <= '9') ||
        (c >= 'A' && c <= 'F') ||
        (c >= 'a' && c <= 'f')) {
      cleaned += c;
    }
  }

  cleaned.toUpperCase();
  return cleaned;
}

bool readRFID(String &tagOut) {
  while (Serial2.available()) {
    char c = (char)Serial2.read();

    if (c == '\n' || c == '\r') {
      if (rfidBuffer.length() > 0) {
        tagOut = cleanTag(rfidBuffer);
        rfidBuffer = "";
        return tagOut.length() > 0;
      }
    } else {
      rfidBuffer += c;

      if (rfidBuffer.length() > 64) {
        rfidBuffer = "";
      }
    }
  }

  return false;
}

