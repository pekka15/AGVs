// =====================================================
// MODE FILTERING
// =====================================================
Mode readModeSwitchRaw() {
  int autoState   = digitalRead(MODE_AUTO_PIN);
  int manualState = digitalRead(MODE_MANUAL_PIN);

  if (autoState == LOW) {
    return MODE_AUTO;
  }
  if (manualState == LOW) {
    return MODE_MANUAL;
  }
  return MODE_STOP;
}

Mode readModeSwitch() {
  Mode rawMode = readModeSwitchRaw();

  if (rawMode != lastRawMode) {
    lastRawMode = rawMode;
    modeDebounceStart = millis();
  }

  if ((millis() - modeDebounceStart) >= MODE_DEBOUNCE_MS) {
    if (stableMode != rawMode) {
      modeChangeFrom = stableMode;
      modeChangeTo   = rawMode;
      stableMode = rawMode;
      modeChangedFlag = true;
    }
  }

  return stableMode;
}

void handleModeTransition(Mode oldMode, Mode newMode) {
  Serial.print("Stable mode change: ");
  Serial.print(modeToText(oldMode));
  Serial.print(" -> ");
  Serial.println(modeToText(newMode));

  char dbg[24];
  snprintf(dbg, sizeof(dbg), "MODE_%s", modeToShortText(newMode));
  sendDebugToMaster(dbg);

  if (oldMode == MODE_AUTO && newMode != MODE_AUTO) {
    Serial.println("Leaving AUTO -> resetting AUTO station state");
    stopMotors();
    resetAutoStationState();
    sendDebugToMaster("LEAVE_AUTO_RST");
  }
}

bool readUltraFrame(uint8_t *buf) {
  static uint8_t idx = 0;

  while (RS485.available()) {
    uint8_t b = RS485.read();

    if (idx == 0 && b != 0x55) continue;
    if (idx == 1 && b != 0xAA) { idx = 0; continue; }

    buf[idx++] = b;

    if (idx == 8) {
      idx = 0;
      return true;
    }
  }
  return false;
}

void updateUltrasonicRS485()
{
  static unsigned long lastRun = 0;
  static unsigned long sendTime = 0;
  static bool waiting = false;
  static uint8_t buf[8];

  // Run every 100 ms
  if (millis() - lastRun < 100) return;
  lastRun = millis();

  // ================= STEP 1: SEND =================
  if (!waiting)
  {
    // clear buffer
    while (RS485.available()) RS485.read();

    digitalWrite(RS485_DE, HIGH);
    delayMicroseconds(200);

    RS485.write(ultraCmd, sizeof(ultraCmd));
    RS485.flush();

    delayMicroseconds(200);
    digitalWrite(RS485_DE, LOW);

    sendTime = millis();
    waiting = true;

    return;
  }

  // ================= STEP 2: READ =================
  if (waiting && (millis() - sendTime > 80))   // give sensor time
  {
    waiting = false;

    if (readUltraFrame(buf))
    {
      uint8_t checksum = 0;
      for (int i = 0; i < 7; i++) checksum += buf[i];

      if (buf[0] == 0x55 && buf[1] == 0xAA && checksum == buf[7])
      {
        int distance = (buf[5] << 8) | buf[6];

        Serial.print("ULTRA DIST: ");
        Serial.println(distance);

        updateUltrasonicScaling(distance);
      }
    }
  }
}




void setup() {
  Serial.begin(115200);
  delay(1000);

  
  Serial.println();
  Serial.println("ESP32 AGV MAG SENSOR START");

  // ================= INPUTS =================
  pinMode(MODE_AUTO_PIN, INPUT);
  pinMode(MODE_MANUAL_PIN, INPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(BUMPER_PIN, INPUT_PULLUP);
  // ================= RFID =================
  

  // ================= RS485 ULTRASONIC =================
  pinMode(RS485_DE, OUTPUT);
  digitalWrite(RS485_DE, LOW);

  RS485.begin(19200, SERIAL_8N1, RS485_RXD, RS485_TXD);

  Serial.println("RS485 Ultrasonic Ready");

  // ================= WIFI + ESP-NOW =================
  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  delay(200);
  esp_wifi_set_channel(13, WIFI_SECOND_CHAN_NONE);

  Serial.print("Slave MAC: ");
  Serial.println(WiFi.macAddress());

  if (esp_now_init() != ESP_OK) {
    Serial.println("ESP-NOW init failed");
  } else {
    esp_now_register_send_cb(onDataSent);
    esp_now_register_recv_cb(onDataRecv);

    esp_now_peer_info_t peerInfo = {};
    memcpy(peerInfo.peer_addr, masterMAC, 6);
    peerInfo.channel = 13;
    peerInfo.encrypt = false;

    if (esp_now_add_peer(&peerInfo) != ESP_OK) {
      Serial.println("Failed to add master peer");
    } else {
      Serial.println("ESP-NOW ready");
      espNowReady = true;
    }
  }

  // ================= LCD =================
  Wire.begin(21,22);

  lcd.init();
  lcd.backlight();

  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("AGV Control Panel");
  lcd.setCursor(0, 1); lcd.print("Mode:");
  lcd.setCursor(0, 2); lcd.print("LD2:");
  lcd.setCursor(0, 3); lcd.print("Mag:");

  // ================= PWM =================
  if (!ledcAttach(PWM_POS_PIN, PWM_FREQ, PWM_RES_BITS)) {
    Serial.println("PWM attach failed on PWM_POS_PIN");
  }
  if (!ledcAttach(PWM_NEG_PIN, PWM_FREQ, PWM_RES_BITS)) {
    Serial.println("PWM attach failed on PWM_NEG_PIN");
  }

  ledcWrite(PWM_POS_PIN, 0);
  ledcWrite(PWM_NEG_PIN, 0);

  // ================= CAN =================
  SPI.begin(CAN_SCK_PIN, CAN_MISO_PIN, CAN_MOSI_PIN, CAN_CS);

  if (CAN.begin(CANController::Mode::Normal) != CANController::OK) {
    Serial.println("CAN begin failed");
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("CAN begin failed");
    while (1) {
      delay(1000);
    }
  }

  Serial.println("CAN started");
  Serial.println("LD1 LD2 LD3 MagLevel");

  // ================= STATE INIT =================
  stableMode = readModeSwitchRaw();
  lastRawMode = stableMode;
  modeDebounceStart = millis();

  autoMovementFlag = true;
  waitingForContinue = false;
  requestSent = false;
  stoppedAtStation = false;

  sendDebugToMaster("BOOT");

  Serial.println("SYSTEM READY");
}
// =====================================================
// LOOP
// =====================================================
void loop() {

  // =====================================================
  // SERIAL TEST INPUT
  // =====================================================
  if (Serial.available()) {
    String testCmd = Serial.readStringUntil('\n');
    testCmd.trim();

    if (testCmd.length() > 0) {

      Serial.print("SIM INPUT: ");
      Serial.println(testCmd);

      // 🔥 Simulate station arrival
      if (testCmd.startsWith("AT_")) {
        startWaitingAtLocation(testCmd);
      }
      else {
        strncpy(lastCommand, testCmd.c_str(), sizeof(lastCommand) - 1);
        lastCommand[sizeof(lastCommand) - 1] = '\0';
        newCommandReceived = true;
      }
    }
  }

  // =====================================================
  // CAN READ
  // =====================================================
  CANFrame frame;
  if (CAN.read(frame) == CANController::IOResult::OK) {
    if (frame.getId() == TPDO1_ID && frame.getDlc() == 8) {
      const uint8_t* d = frame.getData();

      LD1 = le_i16(d[0], d[1]);
      LD2 = le_i16(d[2], d[3]);
      LD3 = le_i16(d[4], d[5]);

      magLevel = (d[7] >> 1) & 0x07;
      lastCanRxTime = millis();

      LD2_filtered = LD2_ALPHA * LD2 + (1.0f - LD2_ALPHA) * LD2_filtered;
      updateLCDValues();
      // ================= MARKER EXTRACTION =================
      uint8_t rawMarker = d[6];
      uint8_t sensorCode = rawMarker >> 4;

      // ================= MAP TO 1–3 =================
      uint8_t marker = 0;

      if (sensorCode == 1) marker = 1;   // 30mm
      else if (sensorCode == 2) marker = 2;  // 60mm
      else if (sensorCode == 3) marker = 3;  // 90mm
      else marker = 0;   // ignore everything else

      // Simple edge detection (only trigger when marker changes)
      static uint8_t lastMarker = 0;

      if (marker != 0 && marker != lastMarker)
      {
        Serial.print("DETECTED MARKER: ");
        Serial.println(marker);

        handleFinalMarker(marker);
      }

      lastMarker = marker;
    }
  }

  // =====================================================
  // CHARGING
  // =====================================================
  static unsigned long lastCharge = 0;
  if (millis() - lastCharge > 200) {
    lastCharge = millis();
    checkChargingAndSend();
  }

  // =====================================================
  // MASTER COMMAND
  // =====================================================
  if (newCommandReceived) {
    newCommandReceived = false;
    handleMasterCommand(lastCommand);
  }

  // =====================================================
  // MODE
  // =====================================================
  Mode currentMode = readModeSwitch();

  if (modeChangedFlag) {
    modeChangedFlag = false;
    handleModeTransition(modeChangeFrom, modeChangeTo);
  }

  // =====================================================
  // AUTO MODE (FIXED)
  // =====================================================
  if (currentMode == MODE_AUTO) {
    bool bumperActive = false;

    // =====================================================
    // ONLY ALLOW BUMPER WHEN NOT APPROACHING STATION
    // =====================================================
    if (!stationDetectionActive)
    {
      bumperActive = (digitalRead(BUMPER_PIN) == LOW);
    }

    if (bumperActive)
    {
      stopMotors();
      Serial.println("BUMPER HIT!");
      return;
    }
    if (ultrasonicEnabled && ultrasonicStop) {
      stopMotors();
    }
    updateLCDMode(waitingForContinue ? "WAIT" : "AUTO");

    // 🔥 Ultrasonic update
    if (ultrasonicEnabled) {
      updateUltrasonicRS485();
    } 
    else {
    ultrasonicStop = false;   // prevents ghost stops
}

    // 🔥 HARD STOP PRIORITY (ONLY ONE PLACE)
    if (ultrasonicEnabled && ultrasonicStop) {
      stopMotors();
    }

    else if (stoppedAtStation) {
      stopMotors();

      if (buttonPressedEvent()) {
        triggerManualStationRequest();
      }

      handleWaitingRequests();
    }

    else if (!autoMovementFlag) {
      stopMotors();
    }

    else if ((millis() - lastCanRxTime) > CAN_TIMEOUT_MS) {
      stopMotors();
    }

    else if (magLevel >= 1) {
      MaglinTracking((int16_t)LD2_filtered, dutyNeg, dutyPos);
    }

    else {
      stopMotors();
    }
  }

  // =====================================================
  // MANUAL
  // =====================================================
  else if (currentMode == MODE_MANUAL) {
    updateLCDMode("MANUAL");
    runManualFullSpeed();
  }

  // =====================================================
  // STOP
  // =====================================================
  else {
    updateLCDMode("STOP");
    stopMotors();
  }

  // =====================================================
  // DEBUG
  // =====================================================
  if (millis() - lastSerialPrint >= SERIAL_PRINT_MS) {
    lastSerialPrint = millis();
    printDebug(currentMode);
  }
}

