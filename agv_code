bool parseContinueSpeedStep(const char* cmd, int &stepOut) {
  if (strncmp(cmd, "CONTINUE_", 9) != 0) {
    return false;
  }

  int step = atoi(cmd + 9);

  if (step < 1 || step > 15) {
    return false;
  }

  stepOut = step;
  return true;
}

void updateSpeedScaleFromStep(int step) {
  if (step < 1) step = 1;
  if (step > 15) step = 15;

  commandedSpeedStep = step;

  commandedSpeedScale =
    MIN_SPEED_SCALE +
    ((float)(step - 1) / 14.0f) * (MAX_SPEED_SCALE - MIN_SPEED_SCALE);

  Serial.print("Speed step set to ");
  Serial.print(commandedSpeedStep);
  Serial.print(" -> scale = ");
  Serial.println(commandedSpeedScale, 3);
}

uint16_t applySpeedScale(uint16_t dutyIn) {

  float scaled = (float)dutyIn;

  // Master speed scaling (existing system)
  scaled *= commandedSpeedScale;

  // Ultrasonic scaling (NEW)
  scaled *= ultrasonicScale;

  if (scaled < 0.0f) scaled = 0.0f;
  if (scaled > PWM_MAX) scaled = PWM_MAX;

  return (uint16_t)scaled;
}

void handleMasterCommand(const char* cmd) {
  int parsedStep = 0;

  if (parseContinueSpeedStep(cmd, parsedStep)) {
    updateSpeedScaleFromStep(parsedStep);

    autoMovementFlag = true;
    waitingForContinue = false;
    requestSent = false;
    stoppedAtStation = false;

    waitingForPermission = false;
    waitingArrivalMessage = "";
    waitingRequestMessage = "";

    Serial.print("Master allowed movement with speed step ");
    Serial.println(parsedStep);

    char dbg[24];
    snprintf(dbg, sizeof(dbg), "CMD_CONT_%d", parsedStep);
    sendDebugToMaster(dbg);
    return;
  }

  if (strcmp(cmd, "REPORT_LOCATION") == 0)
  {
      // IF MOVING -> IGNORE
      if (!stoppedAtStation)
      {
          Serial.println("NOT AT STATION -> IGNORING REPORT_LOCATION");
          return;
      }

      // STATIONARY -> REPORT
      if (currentStationMessage.length() > 0)
      {
          sendToMaster(currentStationMessage.c_str());

          Serial.print("Reported location: ");
          Serial.println(currentStationMessage);
      }

      return;
  }

  if (strcmp(cmd, "CONTINUE") == 0) {
    autoMovementFlag = true;
    waitingForContinue = false;
    requestSent = false;
    stoppedAtStation = false;

    waitingForPermission = false;
    waitingArrivalMessage = "";
    waitingRequestMessage = "";

    Serial.println("Master allowed AUTO movement again");
    sendDebugToMaster("CMD_CONT");
    return;
  }

  if (strcmp(cmd, "WAIT") == 0 ||
      strcmp(cmd, "STOP") == 0 ||
      strcmp(cmd, "STOP_OP2") == 0 ||
      strcmp(cmd, "STOP_OP3") == 0) {
    autoMovementFlag = false;
    waitingForContinue = true;
    requestSent = false;
    stoppedAtStation = true;

    Serial.print("Master sent stop/wait command: ");
    Serial.println(cmd);

    sendDebugToMaster("CMD_STOPWAIT");
    return;
  }

  if (strcmp(cmd, "MOVE") == 0 ||
      strcmp(cmd, "MOVE_OP2") == 0 ||
      strcmp(cmd, "MOVE_OP3") == 0) {
    autoMovementFlag = true;
    waitingForContinue = false;
    requestSent = false;
    stoppedAtStation = false;

    waitingForPermission = false;
    waitingArrivalMessage = "";
    waitingRequestMessage = "";

    Serial.print("Master sent move command: ");
    Serial.println(cmd);

    sendDebugToMaster("CMD_MOVE");
    return;
  }

  Serial.print("Unknown master command: ");
  Serial.println(cmd);

  sendDebugToMaster("CMD_UNKNOWN");
}

